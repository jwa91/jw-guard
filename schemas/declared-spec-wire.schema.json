        }
      },
      "required": [
        "name",
        "role"
      ],
      "type": "object"
    },
    "WireBoundarySpec": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "side_a_anchor": {
          "type": "string"
